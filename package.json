{
  "name": "ncore",
  "private": true,
  "version": "11.7.96",
  "description": "NCore desktop and web communication platform by NYPTID Industries Advanced Technologies.",
  "author": {
    "name": "NYPTID Industries Advanced Technologies"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "audio:assets:sync": "node scripts/sync-ai-denoiser-assets.cjs",
    "build": "npm run audio:assets:sync && vite build",
    "build:electron:web": "npm run audio:assets:sync && set NCORE_ELECTRON_BUILD=1&& vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "desktop": "npm run build:electron:web && electron .",
    "build:mobile:web": "npm run build && node scripts/prepare-mobile-web.cjs",
    "sync:android:mobile": "set CAPACITOR_WEB_DIR=dist-mobile&& npx cap sync android",
    "build:apk:debug": "npm run build:mobile:web && npm run sync:android:mobile && cd android && gradlew.bat assembleDebug --no-daemon",
    "build:apk:release": "npm run build:mobile:web && npm run sync:android:mobile && cd android && gradlew.bat assembleRelease --no-daemon",
    "icons:sync": "node scripts/sync-brand-icons.cjs",
    "version:bump": "node scripts/bump-version.cjs patch",
    "build:exe": "npm run icons:sync && npm run build:electron:web && electron-builder --win nsis --x64 -c.win.signAndEditExecutable=false",
    "build:exe:portable": "npm run icons:sync && npm run build:electron:web && electron-builder --win portable --x64 -c.win.signAndEditExecutable=false",
    "build:exe:auto:nobump": "npm run icons:sync && npm run build:electron:web && electron-builder --win nsis --x64 -c.win.signAndEditExecutable=false && node scripts/sync-update-feed.cjs",
    "build:exe:auto": "npm run version:bump && npm run icons:sync && npm run build:electron:web && electron-builder --win nsis --x64 -c.win.signAndEditExecutable=false && node scripts/sync-update-feed.cjs",
    "release:web": "node scripts/release-web.cjs",
    "release:web:auto": "npm run version:bump && node scripts/release-web.cjs",
    "release:update": "npm run build:exe:auto && npm run release:web"
  },
  "dependencies": {
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "@supabase/supabase-js": "^2.57.4",
    "electron-updater": "^6.6.2",
    "livekit-client": "^2.18.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "agora-extension-ai-denoiser": "^2.0.1",
    "agora-rtc-react": "^2.5.1",
    "agora-rtc-sdk-ng": "^4.24.2",
    "autoprefixer": "^10.4.18",
    "electron": "^35.0.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "playwright": "^1.58.2",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "rcedit": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "simple-icons": "^16.12.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.nyptid.ncore",
    "productName": "NCore",
    "executableName": "NCore",
    "copyright": "Copyright © 2026 NYPTID Industries Advanced Technologies",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/updates{,/**/*}",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/assets/ncore-icon.ico",
        "to": "ncore-icon.ico"
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://ncore.nyptidindustries.com/updates"
      }
    ],
    "afterPack": "scripts/after-pack.cjs",
    "win": {
      "signAndEditExecutable": false,
      "legalTrademarks": "NYPTID Industries Advanced Technologies",
      "icon": "electron/assets/ncore-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "include": "build/installer.nsh",
      "shortcutName": "NCore",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "installerIcon": "electron/assets/ncore-icon.ico",
      "uninstallerIcon": "electron/assets/ncore-icon.ico",
      "installerHeaderIcon": "electron/assets/ncore-icon.ico"
    }
  }
}
